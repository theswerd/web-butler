{
  "name": "web-butler",
  "description": "Web Butler monorepo — shared UI package, browser extension, Storybook",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @web-butler/extension",
    "dev:chrome": "node scripts/watch-build.mjs",
    "server": "npm run dev -w @web-butler/server",
    "build": "npm run build -w @web-butler/extension",
    "storybook": "npm run dev -w @web-butler/storybook",
    "build:storybook": "npm run build -w @web-butler/storybook",
    "compile": "npm run compile --workspaces --if-present"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "spawn-sync@1.0.15": true,
    "fsevents@2.3.3": true
  }
}
