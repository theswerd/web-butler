# Neon Postgres connection string (Dashboard → Connect → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# openssl rand -base64 32
BETTER_AUTH_SECRET=

# Comma-separated extension origins allowed to call the API, e.g.
# chrome-extension://abcdefghijklmnop
WEB_BUTLER_EXTENSION_ORIGINS=

# Freestyle credential for sandbox creation (dashboard API key preferred,
# CLI access token also works)
FREESTYLE_API_KEY=
# FREESTYLE_ACCESS_TOKEN=

# Default VM snapshot for new sandboxes, built by `npm run snapshot:build`
# (comes with claude, codex, and grok CLIs preinstalled)
FREESTYLE_SNAPSHOT_ID=
