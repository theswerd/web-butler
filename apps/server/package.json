{
  "name": "@web-butler/server",
  "description": "Web Butler API server — Hono + Better Auth",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "auth:generate": "npx @better-auth/cli generate -y --config src/auth.ts --output src/db/auth-schema.ts",
    "snapshot:build": "tsx scripts/build-snapshot.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "compile": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@hono/standard-validator": "^0.2.3",
    "@neondatabase/serverless": "^1.1.0",
    "@scalar/hono-api-reference": "^0.11.11",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "freestyle": "^0.1.63",
    "hono": "^4.12.31",
    "hono-openapi": "^1.3.1",
    "zod": "^4.4.3"
  }
}
